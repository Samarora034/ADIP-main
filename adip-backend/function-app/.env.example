# ─────────────────────────────────────────────────────────────────
# ADIP Function App — Environment Variables
# Copy this file to .env and fill in your values.
# These are also set as Azure Function App Settings in the portal.
# ─────────────────────────────────────────────────────────────────

# ── Azure Cosmos DB ───────────────────────────────────────────────
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_KEY=<your-cosmos-primary-key>
COSMOS_DB=adip-db
COSMOS_CONTAINER_DRIFT=drift-records
COSMOS_CONTAINER_BASELINE=baselines

# ── Express API (for Socket.IO push after drift detection) ────────
# Use the deployed App Service URL in production
EXPRESS_API_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────────
# ADIP Express API — Environment Variables
# Copy this file to .env and fill in your values.
# Run: cp .env.example .env
# ─────────────────────────────────────────────────────────────────

PORT=3001


# Get from: Azure Portal → Cosmos DB account → Keys

# ── Azure Storage Queue (real-time change feed) ───────────────────
# Get from: Azure Portal → Storage Account → Access keys
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
STORAGE_QUEUE_NAME=resource-changes
QUEUE_POLL_INTERVAL_MS=5000

# ── Azure Identity (for ARM API calls) ────────────────────────────
# Used by DefaultAzureCredential — no value needed if using az login locally
# In production (App Service), assign a Managed Identity with Reader + Contributor roles
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_TENANT_ID=<your-tenant-id>

# ── Azure Function App ────────────────────────────────────────────
FUNCTION_APP_URL=https://<your-func>.azurewebsites.net/api

# ── Azure Event Grid ──────────────────────────────────────────────
EVENTGRID_TOPIC_ENDPOINT=https://<your-eg-topic>.eventgrid.azure.net/api/events
EVENTGRID_TOPIC_KEY=<your-eventgrid-key>

# ── Drift Alert Logic App ─────────────────────────────────────────
# Get from: Azure Portal → Logic App → adip-drift-alert → Overview → Trigger URL
ALERT_LOGIC_APP_URL=https://prod-xx.westus2.logic.azure.com:443/workflows/<id>/triggers/HTTP_Drift_Alert/paths/invoke?...

# ── Azure Communication Services (Email Alerts) ───────────────────
# Get from: Azure Portal → Communication Services → adip-comms → Keys
COMMS_CONNECTION_STRING=endpoint=https://<your-comms>.communication.azure.com/;accesskey=<key>
SENDER_ADDRESS=DoNotReply@<your-domain>.azurecomm.net

# Comma-separated list of alert recipients
# Example: user1@company.com,user2@company.com
ALERT_RECIPIENT_EMAIL=

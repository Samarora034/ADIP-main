# ─────────────────────────────────────────────────────────────────
# ADIP Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# Express API base URL (no trailing slash)
# Local:      http://localhost:3001/api
# Production: https://<your-app-service>.azurewebsites.net/api
VITE_API_BASE_URL=http://localhost:3001/api

# Socket.IO server URL (same host as Express API, without /api)
VITE_SOCKET_URL=http://localhost:3001

# Azure AD (optional — for future SSO integration)
VITE_AZURE_CLIENT_ID=<your-app-registration-client-id>
VITE_AZURE_TENANT_ID=<your-tenant-id>
